<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF000000"
    android:fitsSystemWindows="true">

    <!-- Camera + Overlay (fullscreen) -->
    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.armeasure.app.MeasureOverlayView
        android:id="@+id/overlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="@id/surfaceView"
        app:layout_constraintBottom_toBottomOf="@id/surfaceView"
        app:layout_constraintStart_toStartOf="@id/surfaceView"
        app:layout_constraintEnd_toEndOf="@id/surfaceView" />

    <!-- Top info card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/topInfoCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="56dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp">

            <!-- Left: mode + sensor -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tap_to_measure"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSensor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sensor_detecting"
                    android:textColor="#888888"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Right: distance -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="@color/accent"
                    android:textSize="48sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false"
                    tools:text="1.52m" />

                <TextView
                    android:id="@+id/tvUncertainty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/text_dim"
                    android:textSize="14sp"
                    android:fontFamily="monospace"
                    android:includeFontPadding="false" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Calibration tiny indicator -->
    <TextView
        android:id="@+id/tvCalibration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text=""
        android:textColor="@color/text_dim"
        android:textSize="9sp"
        app:layout_constraintTop_toBottomOf="@id/topInfoCard"
        app:layout_constraintStart_toStartOf="@id/topInfoCard"
        app:layout_constraintEnd_toEndOf="@id/topInfoCard" />

    <!-- Settings gear (top-left) -->
    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_preferences"
        android:contentDescription="@string/settings"
        android:scaleType="centerInside"
        android:padding="8dp"
        app:tint="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Reset FAB (top-right) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabReset"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/reset"
        app:fabSize="mini"
        app:srcCompat="@android:drawable/ic_menu_revert"
        app:backgroundTint="#44FFFFFF"
        app:tint="@color/text_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom action bar (pill-shaped mode selector) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomActionBar"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="48dp"
        android:layout_marginBottom="8dp"
        app:cardBackgroundColor="#CC000000"
        app:cardCornerRadius="40dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/modeButtonContainer"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="4dp">

                <!-- Mode: Point -->
                <LinearLayout
                    android:id="@+id/btnPointMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_point" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_point"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Line -->
                <LinearLayout
                    android:id="@+id/btnLineMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_line"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Area -->
                <LinearLayout
                    android:id="@+id/btnAreaMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_crop"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_area" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_area"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Sweep -->
                <LinearLayout
                    android:id="@+id/btnSweepMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_rotate"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_sweep" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_sweep"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Height -->
                <LinearLayout
                    android:id="@+id/btnHeightMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_upload"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_height" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_height"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Angle -->
                <LinearLayout
                    android:id="@+id/btnAngleMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_compass"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_angle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_angle"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- Mode: Level -->
                <LinearLayout
                    android:id="@+id/btnLevelMode"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:minWidth="48dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="8dp"
                    android:background="?attr/selectableItemBackgroundBorderless">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        app:tint="@color/text_primary"
                        android:contentDescription="@string/mode_level" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mode_level"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>
        </HorizontalScrollView>
    </com.google.android.material.card.MaterialCardView>

    <!-- Floating action group: save + undo + history (bottom-right) -->
    <LinearLayout
        android:id="@+id/floatingActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="84dp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Save -->
        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/floating_action_bg"
            android:src="@android:drawable/ic_menu_save"
            android:contentDescription="@string/save"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/text_primary" />

        <!-- Undo -->
        <ImageButton
            android:id="@+id/btnUndo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/floating_action_bg"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/undo"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/text_primary" />

        <!-- History -->
        <ImageButton
            android:id="@+id/btnHistory"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/floating_action_bg"
            android:src="@android:drawable/ic_menu_recent_history"
            android:contentDescription="@string/history"
            android:scaleType="centerInside"
            android:padding="8dp"
            app:tint="@color/text_primary" />

    </LinearLayout>

    <!-- Progress overlay (hidden by default) -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:indeterminateTint="@color/accent"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topInfoCard"
        app:layout_constraintEnd_toEndOf="@id/topInfoCard"
        app:layout_constraintBottom_toTopOf="@id/bottomActionBar" />

</androidx.constraintlayout.widget.ConstraintLayout>
