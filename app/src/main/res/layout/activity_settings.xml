<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF111111">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- Default Unit -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="默认单位"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rgUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">
            <RadioButton android:id="@+id/rbCm" android:text="厘米" android:textColor="#FFFFFF" android:layout_marginEnd="24dp" />
            <RadioButton android:id="@+id/rbInch" android:text="英寸" android:textColor="#FFFFFF" android:layout_marginEnd="24dp" />
            <RadioButton android:id="@+id/rbM" android:text="米" android:textColor="#FFFFFF" />
        </RadioGroup>

        <!-- Show Uncertainty -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="显示精度范围 (±)"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/swUncertainty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Haptic Feedback -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="触觉反馈"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/swHaptic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Depth Camera Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="深度摄像头"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
            <Switch
                android:id="@+id/swDepth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Calibrate -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalibrate"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="传感器校准"
            android:textColor="#00FF88"
            android:layout_marginBottom="8dp"
            android:strokeColor="#00FF88" />

        <!-- Clear History -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearHistory"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="清空所有历史记录"
            android:textColor="#FF4444"
            android:layout_marginBottom="24dp"
            android:strokeColor="#FF4444" />

        <!-- About -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AR测距 v1.1"
            android:textColor="#666666"
            android:textSize="12sp"
            android:layout_gravity="center" />
    </LinearLayout>
</ScrollView>
